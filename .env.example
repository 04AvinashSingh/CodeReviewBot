# ── GitHub App ───────────────────────────────────────────────────
GITHUB_APP_ID=your-app-id
GITHUB_WEBHOOK_SECRET=your-webhook-secret
# Place your GitHub App private key as: ./github-private-key.pem

# ── Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-256-bit-secret-at-least-32-characters

# ── Database (only needed for local dev without Docker) ──────────
DB_URL=jdbc:postgresql://localhost:5432/codereviewbot
DB_USERNAME=postgres
DB_PASSWORD=postgres
